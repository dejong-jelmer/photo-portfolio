---
import "../styles/global.css";
import { Image } from "astro:assets";
import J from "../image/J.png";
import ThemeToggle from "../components/ThemeToggle.astro";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR } from "../config";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;
const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <!-- Runs before first paint to avoid a light-mode flash on dark-mode visits. -->
    <script is:inline>
      (() => {
        let theme;
        try {
          theme = localStorage.getItem("theme");
        } catch {}
        if (theme !== "light" && theme !== "dark") {
          theme = matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="flex min-h-dvh flex-col bg-bg font-sans text-fg antialiased">
    <header class="mx-auto w-full max-w-7xl px-3 py-8 sm:px-4 sm:py-10">
      <div class="flex items-baseline justify-between">
        <div class="inline-flex">
          <a
            href="/"
            class="inline-flex items-center gap-6 text-xl font-bold tracking-[0.3em] uppercase hover:text-muted"
          >
            <Image src={J} alt="" width={48} height={48} class="size-12 rounded-md" />
            {SITE_TITLE}
          </a>
        </div>
        <nav class="flex items-center gap-5">
          <!-- Desktop: link + schakelaar naast elkaar -->
          <div class="hidden items-center gap-5 sm:flex">
            <a
              href="/about/"
              class="text-md tracking-widest text-muted uppercase transition-colors hover:text-fg"
            >
              Over {SITE_AUTHOR}
            </a>
            <ThemeToggle />
          </div>
          <!-- Mobiel: hamburgerknop die het menu hieronder opent -->
          <button
            id="menu-toggle"
            type="button"
            aria-label="Menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="-mr-1 inline-flex size-9 cursor-pointer items-center justify-center rounded-md text-fg transition-colors hover:text-muted sm:hidden"
          >
            <svg
              class="menu-icon-open size-6"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="4" x2="20" y1="6" y2="6"></line>
              <line x1="4" x2="20" y1="12" y2="12"></line>
              <line x1="4" x2="20" y1="18" y2="18"></line>
            </svg>
            <svg
              class="menu-icon-close hidden size-6"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </nav>
      </div>
      <!-- Mobiel uitklapmenu -->
      <div id="mobile-menu" class="hidden sm:hidden">
        <div
          class="mt-5 flex flex-col gap-5 border-t border-muted/20 pt-5"
        >
          <a
            href="/about/"
            class="text-md tracking-widest text-muted uppercase transition-colors hover:text-fg"
          >
            Over {SITE_AUTHOR}
          </a>
          <div class="flex items-center gap-3">
            <span class="text-md tracking-widest text-muted uppercase">
              Thema
            </span>
            <ThemeToggle />
          </div>
        </div>
      </div>
    </header>
    <main class="mx-auto w-full max-w-7xl flex-1 px-3 pb-12 sm:px-4">
      <slot />
    </main>
    <footer class="mx-auto w-full max-w-7xl px-3 pb-8 sm:px-4">
      <p class="text-xs text-muted">
        © {new Date().getFullYear()}
        {SITE_AUTHOR}
      </p>
    </footer>
    <script>
      const root = document.documentElement;
      const toggles = document.querySelectorAll(".theme-toggle");

      function syncSwitch() {
        const checked = String(root.dataset.theme === "dark");
        toggles.forEach((t) => t.setAttribute("aria-checked", checked));
      }

      syncSwitch();
      toggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
          const next = root.dataset.theme === "dark" ? "light" : "dark";
          root.dataset.theme = next;
          try {
            localStorage.setItem("theme", next);
          } catch {}
          syncSwitch();
        });
      });

      // Mobiel hamburgermenu open/dicht.
      const menuToggle = document.getElementById("menu-toggle");
      const mobileMenu = document.getElementById("mobile-menu");

      function setMenuOpen(open: boolean) {
        menuToggle?.setAttribute("aria-expanded", String(open));
        mobileMenu?.classList.toggle("hidden", !open);
        menuToggle
          ?.querySelector(".menu-icon-open")
          ?.classList.toggle("hidden", open);
        menuToggle
          ?.querySelector(".menu-icon-close")
          ?.classList.toggle("hidden", !open);
      }

      menuToggle?.addEventListener("click", () => {
        setMenuOpen(mobileMenu?.classList.contains("hidden") ?? false);
      });

      // Sluit het menu bij navigatie of als het scherm naar desktop groeit.
      matchMedia("(min-width: 640px)").addEventListener("change", (e) => {
        if (e.matches) setMenuOpen(false);
      });
    </script>
  </body>
</html>

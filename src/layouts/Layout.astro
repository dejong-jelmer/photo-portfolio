---
import "../styles/global.css";
import { Image } from "astro:assets";
import J from "../image/J.png";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_AUTHOR } from "../config";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE_DESCRIPTION } = Astro.props;
const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <!-- Runs before first paint to avoid a light-mode flash on dark-mode visits. -->
    <script is:inline>
      (() => {
        let theme;
        try {
          theme = localStorage.getItem("theme");
        } catch {}
        if (theme !== "light" && theme !== "dark") {
          theme = matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="flex min-h-dvh flex-col bg-bg font-sans text-fg antialiased">
    <header class="mx-auto w-full max-w-7xl px-3 py-8 sm:px-4 sm:py-10">
      <div class="flex items-baseline justify-between">
        <div class="inline-flex">
          <a
            href="/"
            class="inline-flex items-center gap-6 text-xl font-bold tracking-[0.3em] uppercase hover:text-muted"
          >
            <Image src={J} alt="" width={48} height={48} class="size-12 rounded-md" />
            {SITE_TITLE}
          </a>
        </div>
        <nav class="flex items-center gap-5">
          <a
            href="/about/"
            class="text-md tracking-widest text-muted uppercase transition-colors hover:text-fg"
          >
            Over {SITE_AUTHOR}
          </a>
          <button
            id="theme-toggle"
            type="button"
            role="switch"
            aria-checked="false"
            aria-label="Donkere modus"
            class="relative h-5 w-9 cursor-pointer rounded-full border border-muted/40 transition-colors hover:border-muted"
          >
            <span
              class="theme-toggle-thumb absolute top-0.5 left-0.5 size-3.5 rounded-full bg-fg transition-transform duration-200"
            ></span>
          </button>
        </nav>
      </div>
    </header>
    <main class="mx-auto w-full max-w-7xl flex-1 px-3 pb-12 sm:px-4">
      <slot />
    </main>
    <footer class="mx-auto w-full max-w-7xl px-3 pb-8 sm:px-4">
      <p class="text-xs text-muted">
        © {new Date().getFullYear()}
        {SITE_AUTHOR}
      </p>
    </footer>
    <script>
      const toggle = document.getElementById("theme-toggle");
      const root = document.documentElement;

      function syncSwitch() {
        toggle?.setAttribute(
          "aria-checked",
          String(root.dataset.theme === "dark"),
        );
      }

      syncSwitch();
      toggle?.addEventListener("click", () => {
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch {}
        syncSwitch();
      });
    </script>
  </body>
</html>

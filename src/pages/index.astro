---
import Layout from '../layouts/Layout.astro';
import Tile from '../components/Tile.astro';
import { getGalleryItems } from '../lib/gallery';
import { EAGER_TILES } from '../config';

const items = getGalleryItems();
---

<Layout>
  <section class="grid grid-cols-2 gap-1 sm:grid-cols-3 sm:gap-1.5 lg:grid-cols-4 xl:grid-cols-5">
    {items.map((item, index) => <Tile item={item} eager={index < EAGER_TILES} />)}
  </section>
</Layout>

<script>
  import { initLightbox } from '../scripts/lightbox';
  initLightbox();
</script>

---
import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { GalleryItem } from '../lib/gallery';

interface Props {
  item: GalleryItem;
  eager?: boolean;
}

const { item, eager = false } = Astro.props;

// One large variant per format for the lightbox. Width is clamped to the
// source so the data-pswp-* dimensions always match the generated file.
const LARGE_WIDTH = 2560;

async function largeVariant(image: ImageMetadata) {
  const width = Math.min(LARGE_WIDTH, image.width);
  const height = Math.round((width / image.width) * image.height);
  const [avif, webp] = await Promise.all([
    getImage({ src: image, width, format: 'avif' }),
    getImage({ src: image, width, format: 'webp' }),
  ]);
  return { avif: avif.src, webp: webp.src, width, height };
}

const large = await Promise.all(item.images.map(({ image }) => largeVariant(image)));
const [coverLarge] = large;
---

<div data-gallery={item.slug}>
  <a
    href={coverLarge.webp}
    data-pswp-width={coverLarge.width}
    data-pswp-height={coverLarge.height}
    data-pswp-avif-src={coverLarge.avif}
    data-alt={item.images[0].alt}
    class="group relative block aspect-square overflow-hidden bg-fg/5"
    aria-label={item.type === 'series' ? `${item.title} (series)` : item.title}
    title={item.caption}
  >
    <Picture
      src={item.cover}
      width={800}
      widths={[400, 800]}
      sizes="(min-width: 1280px) 20vw, (min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
      formats={['avif', 'webp']}
      fallbackFormat="jpeg"
      alt={item.images[0].alt}
      loading={eager ? 'eager' : 'lazy'}
      pictureAttributes={{ class: 'contents' }}
      class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.02]"
    />
    {
      item.type === 'series' && (
        <span class="absolute top-2 right-2 text-white drop-shadow-sm" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 5H9a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Z" />
            <path
              d="M5 3a2 2 0 0 0-2 2v10a1 1 0 0 0 2 0V5h10a1 1 0 0 0 0-2H5Z"
              opacity="0.7"
            />
          </svg>
        </span>
      )
    }
  </a>
  {
    // Hidden anchors complete the series group: PhotoSwipe walks every child
    // anchor regardless of visibility, so clicking the cover opens at index 0
    // and swiping reveals the rest.
    item.images.slice(1).map((img, index) => (
      <a
        href={large[index + 1].webp}
        data-pswp-width={large[index + 1].width}
        data-pswp-height={large[index + 1].height}
        data-pswp-avif-src={large[index + 1].avif}
        data-alt={img.alt}
        class="hidden"
        aria-hidden="true"
        tabindex="-1"
      />
    ))
  }
</div>

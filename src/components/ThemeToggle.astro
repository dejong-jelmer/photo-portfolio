---
/*
 * Donker/licht-schakelaar. Herbruikbaar in de desktop-nav en het mobiele menu.
 * De thumb toont een zonnetje in lichte modus en een maantje in donkere modus;
 * welke zichtbaar is wordt door CSS bepaald (zie global.css). De stand wordt
 * door het script in Layout.astro gesynchroniseerd met data-theme.
 */
---

<button
  type="button"
  role="switch"
  aria-checked="false"
  aria-label="Donkere modus"
  class="theme-toggle relative h-6 w-11 shrink-0 cursor-pointer rounded-full border border-muted/40 transition-colors hover:border-muted"
>
  <span
    class="theme-toggle-thumb absolute top-0.5 left-0.5 flex size-5 items-center justify-center rounded-full bg-fg text-bg transition-transform duration-200"
  >
    <svg
      class="theme-toggle-sun size-3"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="4"></circle>
      <path d="M12 2v2"></path>
      <path d="M12 20v2"></path>
      <path d="m4.93 4.93 1.41 1.41"></path>
      <path d="m17.66 17.66 1.41 1.41"></path>
      <path d="M2 12h2"></path>
      <path d="M20 12h2"></path>
      <path d="m6.34 17.66-1.41 1.41"></path>
      <path d="m19.07 4.93-1.41 1.41"></path>
    </svg>
    <svg
      class="theme-toggle-moon size-3"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
    </svg>
  </span>
</button>
